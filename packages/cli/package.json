{
  "name": "openspecui",
  "version": "5.0.0",
  "description": "OpenSpec UI - Visual interface for spec-driven development",
  "type": "module",
  "main": "dist/index.mjs",
  "bin": {
    "openspecui": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./hooks": {
      "development": "./src/hooks.ts",
      "import": "./dist/hooks.mjs",
      "default": "./dist/hooks.mjs",
      "types": "./dist/hooks.d.mts"
    }
  },
  "files": [
    "dist",
    "web"
  ],
  "scripts": {
    "build": "pnpm run build:web && pnpm run build:copy-web && tsdown",
    "build:web": "pnpm --filter @openspecui/web build",
    "build:copy-web": "rm -rf ./web && cp -r ../web/dist ./web",
    "typecheck": "tsc --noEmit",
    "dev": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--conditions=development\" tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.1.0",
    "@parcel/watcher": "^2.5.1",
    "better-sqlite3": "^12.5.0"
  },
  "// runtime-note": "The published openspecui package installs heavyweight translation runtimes only when the user asks for them.",
  "// bundle-note": "tsdown keeps translator package runtime imports external, so the settings-panel install flow resolves ranges on demand instead of preinstalling them.",
  "optionalDependencies": {
    "ctranslate2": "workspace:*",
    "node-llama-cpp": "~3.18.1"
  },
  "devDependencies": {
    "@hono/node-server": "^1.14.1",
    "@openspecui/core": "workspace:*",
    "@openspecui/server": "workspace:*",
    "@openspecui/web": "workspace:*",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "@types/yargs": "^17.0.35",
    "hono": "^4.7.3",
    "open": "^10.1.0",
    "tsx": "^4.19.2",
    "tsdown": "^0.16.6",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0",
    "yargs": "^18.0.0",
    "yaml": "^2.8.0"
  }
}
