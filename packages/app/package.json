{
  "name": "@openspecui/app",
  "version": "3.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cf:dev": "pnpm build && wrangler pages dev dist",
    "cf:deploy": "pnpm build && wrangler pages deploy dist --project-name openspecui-app",
    "cf:project:create": "wrangler pages project create openspecui-app --production-branch main"
  },
  "devDependencies": {
    "@openspecui/core": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^25.0.1",
    "lucide-react": "^0.472.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.72.0"
  }
}
