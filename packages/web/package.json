{
  "name": "@openspecui/web",
  "version": "3.5.0",
  "type": "module",
  "bin": {
    "openspecui-ssg": "./dist-ssg/ssg-cli.mjs"
  },
  "files": [
    "dist",
    "dist-ssg"
  ],
  "scripts": {
    "dev": "vite --host=0.0.0.0",
    "build": "tsc && vite build && pnpm run build:ssg && pnpm run build:ssg-cli",
    "build:ssg": "pnpm build:ssg-client && pnpm build:ssg-server",
    "build:ssg-client": "vite build --config vite.ssg-client.config.ts --ssrManifest .vite/ssr-manifest.json --outDir dist-ssg/client",
    "build:ssg-server": "vite build --ssr src/ssg/entry-server.tsx --outDir dist-ssg/server",
    "build:ssg-cli": "vite build --config vite.ssg-cli.config.ts --outDir dist-ssg",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:browser": "vitest --retry 2 --project storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:browser:ci": "vitest run --retry 2 --project storybook",
    "build:dist": "vite build --minify false --emptyOutDir false",
    "dev:dist": "vite build --watch --minify false --emptyOutDir true"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.11.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.8",
    "@lezer/common": "^1.4.0",
    "@lezer/highlight": "^1.2.3",
    "@openspecui/search": "workspace:*",
    "@openspecui/server": "workspace:*",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/web-components": "^10.2.19",
    "@storybook/web-components-vite": "^10.2.19",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.62.16",
    "@tanstack/react-router": "^1.99.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@trpc/client": "^11.0.0",
    "@trpc/tanstack-react-query": "^11.0.0",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@types/yargs": "^17.0.35",
    "@uiw/react-codemirror": "^4.25.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@xterm/addon-fit": "0.12.0-beta.167",
    "@xterm/addon-web-links": "0.13.0-beta.167",
    "@xterm/xterm": "6.1.0-beta.167",
    "baseline-browser-mapping": "^2.9.19",
    "clsx": "^2.1.1",
    "ghostty-web": "^0.4.0",
    "jsdom": "^25.0.1",
    "lucide-react": "^0.472.0",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.17.0",
    "storybook": "^10.2.19",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "xterm-input-panel": "workspace:*",
    "yaml": "^2.8.0",
    "yargs": "^18.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fsegurai/codemirror-theme-bundle": "^6.3.1",
    "@rjsf/core": "^6.5.2",
    "@rjsf/utils": "^6.5.2",
    "@rjsf/validator-ajv8": "^6.5.2",
    "view-transitions-toolkit": "1.0.0"
  }
}
