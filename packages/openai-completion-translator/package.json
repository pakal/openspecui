{
  "name": "@openspecui/openai-completion-translator",
  "private": true,
  "version": "5.0.0",
  "description": "OpenAI completion translator engine for OpenSpecUI",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts",
    "dev": "tsdown src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@openspecui/core": "workspace:*",
    "@tanstack/ai": "^0.20.0",
    "@tanstack/ai-openai": "^0.9.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsdown": "^0.16.6",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
