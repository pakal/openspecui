{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["packages/web/src/*"],
      "@openspecui/server": ["packages/server/src/index.ts"],
      "@openspecui/core": ["packages/core/src/index.ts"],
      "@openspecui/core/dashboard-display": ["packages/core/src/dashboard-display.ts"],
      "@openspecui/core/hosted-app": ["packages/core/src/hosted-app.ts"],
      "@openspecui/core/markdown-facts": ["packages/core/src/markdown-facts.ts"],
      "@openspecui/core/markdown-reading": ["packages/core/src/markdown-reading.ts"],
      "@openspecui/core/document-translation": ["packages/core/src/document-translation.ts"],
      "@openspecui/core/notifications": ["packages/core/src/notifications.ts"],
      "@openspecui/core/openspec-annotations": ["packages/core/src/openspec-annotations.ts"],
      "@openspecui/core/openspec-projection": ["packages/core/src/openspec-projection.ts"],
      "@openspecui/core/opsx-display-path": ["packages/core/src/opsx-display-path.ts"],
      "@openspecui/core/opsx-entity": ["packages/core/src/opsx-entity.ts"],
      "@openspecui/core/opsx-schema-detail": ["packages/core/src/opsx-schema-detail.ts"],
      "@openspecui/core/pty-protocol": ["packages/core/src/pty-protocol.ts"],
      "@openspecui/core/sounds": ["packages/core/src/sounds.ts"],
      "@openspecui/core/terminal-audio": ["packages/core/src/terminal-audio.ts"],
      "@openspecui/core/terminal-control": ["packages/core/src/terminal-control.ts"],
      "@openspecui/core/terminal-invocation": ["packages/core/src/terminal-invocation.ts"],
      "@openspecui/core/terminal-theme": ["packages/core/src/terminal-theme.ts"],
      "@openspecui/search": ["packages/search/src/index.ts"],
      "@openspecui/search/node": ["packages/search/src/node.ts"],
      "@openspecui/ai-provider": ["packages/ai-provider/src/index.ts"]
    },
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist", ".git", "**/*.test.ts", "**/*.spec.ts", "references/**"]
}
